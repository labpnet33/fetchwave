{
  "version": 2,
  "functions": {
    "server.js": {
      "maxDuration": 300
    }
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "YTDLP_PATH": "./bin/yt-dlp"
  }
}
